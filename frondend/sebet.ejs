<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Səbətim — Kontakt Home</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');
        
        /* Ümumi Səhifə Ayarları */
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
            font-family: 'Poppins', sans-serif; 
        }
        body { 
            background-color: #0b0b0c; 
            color: #ffffff; 
            padding: 40px 8%; 
        }
        
        /* Başlıq */
        h1 { 
            margin-bottom: 40px; 
            font-weight: 700; 
            font-size: 32px; 
            letter-spacing: -0.5px;
        }
        h1 span { 
            color: #ff0022; 
        }

        /* Əsas ağ qəfəs (Grid) strukturumuz */
        .cart-wrapper { 
            display: flex; 
            gap: 30px; 
            flex-wrap: wrap; 
            align-items: flex-start;
        }
        
        /* Sol tərəf - Məhsulların siyahısı */
        .cart-items { 
            flex: 2; 
            min-width: 400px; 
            display: flex; 
            flex-direction: column; 
            gap: 20px; 
        }
        
        /* Tək bir məhsul kartı */
        .cart-item { 
            background-color: #111113; 
            border: 1px solid #1a1a1c; 
            padding: 24px; 
            border-radius: 16px; 
            display: flex; 
            justify-content: space-between; 
            align-items: center; 
            transition: transform 0.2s, border-color 0.2s;
        }
        .cart-item:hover {
            border-color: #2a2a2e;
            transform: translateY(-2px);
        }
        
        /* Məhsulun yazıları */
        .item-info {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }
        .item-info .brand { 
            color: #ff0022; 
            font-size: 12px; 
            font-weight: 700; 
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .item-info h3 { 
            font-size: 18px; 
            font-weight: 500; 
            color: #ffffff;
        }
        
        /* Məhsulun sağ tərəfi (Qiymət və Sil düyməsi) */
        .item-right { 
            display: flex; 
            align-items: center; 
            gap: 40px; 
        }
        .price { 
            font-size: 22px; 
            font-weight: 700; 
            color: #ffffff;
        }
        
        /* Zibil qutusu / Silmək Düyməsi */
        .delete-btn { 
            background: #1a1a1c; 
            border: none; 
            color: #88888b; 
            font-size: 16px; 
            cursor: pointer; 
            transition: all 0.2s; 
            padding: 10px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .delete-btn:hover { 
            color: #ffffff; 
            background-color: #ff0022;
        }

        /* Sağ tərəf - Sifariş Xülasəsi Paneli */
        .cart-summary { 
            flex: 1; 
            min-width: 320px; 
            background-color: #111113; 
            border: 1px solid #1a1a1c; 
            padding: 30px; 
            border-radius: 16px; 
            position: sticky;
            top: 40px;
        }
        .summary-title { 
            font-size: 20px; 
            font-weight: 600; 
            margin-bottom: 24px; 
            border-bottom: 1px solid #1a1a1c; 
            padding-bottom: 12px; 
        }
        .summary-row { 
            display: flex; 
            justify-content: space-between; 
            margin-bottom: 16px; 
            color: #a0a0a5; 
            font-size: 15px;
        }
        .total-price { 
            font-size: 26px; 
            font-weight: 700; 
            color: #ff0022; 
        }
        
        /* Sifarişi tamamla düyməsi */
        .checkout-btn { 
            width: 100%; 
            background-color: #ff0022; 
            color: white; 
            border: none; 
            padding: 16px; 
            border-radius: 12px; 
            font-size: 16px; 
            font-weight: 600; 
            cursor: pointer; 
            margin-top: 24px; 
            transition: background-color 0.2s; 
        }
        .checkout-btn:hover { 
            background-color: #cc001b; 
        }
        
        /* Boş səbət dizaynı */
        .empty-cart { 
            text-align: center; 
            padding: 80px 20px; 
            color: #88888b; 
            background-color: #111113;
            border: 1px solid #1a1a1c;
            border-radius: 16px;
            font-size: 18px; 
        }
        .back-link { 
            color: #ff0022; 
            text-decoration: none; 
            font-weight: 600; 
            display: inline-block; 
            margin-top: 20px; 
            border: 1px solid #ff0022;
            padding: 10px 24px;
            border-radius: 25px;
            transition: all 0.2s;
        }
        .back-link:hover {
            background-color: #ff0022;
            color: white;
        }
    </style>
</head>
<body>

    <h1>Səbətdəki <span>Məhsullarınız</span></h1>

    <% if (sebetMəhsulları.length === 0) { %>
        <div class="empty-cart">
            <p style="font-size: 40px; margin-bottom: 15px;">🛒</p>
            <p>Səbətiniz hazırda tamamilə boşdur.</p>
            <a href="/mehsullar" class="back-link">Alış-verişə davam et</a>
        </div>
    <% } else { %>
        <div class="cart-wrapper">
            
            <div class="cart-items">
                <% sebetMəhsulları.forEach((item, index) => { %>
                    <div class="cart-item">
                        
                        <div class="item-info">
                            <span class="brand"><%= item.brand %></span>
                            <h3><%= item.title %></h3>
                        </div>
                        
                        <div class="item-right">
                            <div class="price"><%= item.price %> AZN</div>
                            
                            <form action="/sebet/remove" method="POST">
                                <input type="hidden" name="index" value="<%= index %>">
                                <button type="submit" class="delete-btn" title="Səbətdən sil">🗑️</button>
                            </form>
                        </div>

                    </div>
                <% }) %>
            </div>

            <div class="cart-summary">
                <div class="summary-title">Sifariş Xülasəsi</div>
                
                <div class="summary-row">
                    <span>Məhsul sayı:</span>
                    <span style="color: white; font-weight: 500;"><%= sebetMəhsulları.length %> ədəd</span>
                </div>
                
                <div class="summary-row">
                    <span>Çatdırılma:</span>
                    <span style="color: #00ff66; font-weight: 600;">Pulsuz</span>
                </div>
                
                <div class="summary-row" style="border-top: 1px solid #1a1a1c; padding-top: 20px; margin-top: 20px;">
                    <span style="font-size: 16px; font-weight: 500; color: white;">Cəmi Ödəniləcək:</span>
                    <span class="total-price"><%= toplam %> AZN</span>
                </div>
                
                <button class="checkout-btn">🛒 Sifarişi Rəsmiləşdir</button>
                <a href="/mehsullar" style="display: block; text-align: center; margin-top: 15px; color: #88888b; font-size: 13px; text-decoration: none;">← Mağazaya qayıt</a>
            </div>

        </div>
    <% } %>

</body>
</html>