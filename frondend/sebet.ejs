<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <title>Səbət</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #111; color: white; font-family: Arial, sans-serif; }

        nav {
            background: #1a1a1a;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        nav a { color: white; text-decoration: none; font-size: 15px; margin-left: 20px; }
        .logo { font-size: 22px; font-weight: bold; }
        .logo span { color: #e30613; }

        .sebet-page {
            max-width: 900px;
            margin: 40px auto;
            padding: 0 20px;
        }

        h1 { font-size: 28px; margin-bottom: 24px; }
        h1 span { color: #e30613; }

        .empty-box {
            text-align: center;
            padding: 80px 20px;
            color: #666;
        }
        .empty-box p:first-child { font-size: 60px; margin-bottom: 16px; }
        .empty-box p:last-child { font-size: 18px; }

        .sebet-item {
            background: #1e1e1e;
            border-radius: 12px;
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 14px;
        }
        .sebet-item img {
            width: 80px;
            height: 80px;
            object-fit: contain;
            border-radius: 8px;
            background: #2a2a2a;
        }
        .item-info { flex: 1; }
        .item-info h3 { font-size: 16px; margin-bottom: 6px; }
        .item-info p { color: #aaa; font-size: 14px; }
        .item-qiymet { font-size: 18px; font-weight: bold; color: #e30613; min-width: 100px; text-align: right; }
        .sil-btn {
            background: #2a2a2a;
            border: none;
            color: #aaa;
            font-size: 20px;
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: 0.2s;
        }
        .sil-btn:hover { background: #e30613; color: white; }

        .summary {
            background: #1e1e1e;
            border-radius: 12px;
            padding: 24px;
            margin-top: 24px;
        }
        .summary-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            color: #aaa;
        }
        .summary-total {
            display: flex;
            justify-content: space-between;
            font-size: 22px;
            font-weight: bold;
            border-top: 1px solid #333;
            padding-top: 16px;
            margin-top: 8px;
        }
        .summary-total span:last-child { color: #e30613; }

        .checkout-btn {
            display: block;
            width: 100%;
            margin-top: 20px;
            padding: 16px;
            background: #e30613;
            color: white;
            font-size: 17px;
            font-weight: bold;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.2s;
        }
        .checkout-btn:hover { background: #c0000f; }

        .geri-btn {
            display: inline-block;
            margin-bottom: 24px;
            color: #aaa;
            text-decoration: none;
            font-size: 15px;
        }
        .geri-btn:hover { color: white; }
    </style>
</head>
<body>

<nav>
    <div class="logo">Kontakt<span>Home</span></div>
    <div>
        <a href="/">Ana Səhifə</a>
        <a href="/mehsullar">Məhsullar</a>
        <a href="/brendler">Brendlər</a>
        <a href="/kampaniyalar">Kampaniyalar</a>
    </div>
</nav>

<div class="sebet-page">
    <a href="/mehsullar" class="geri-btn">← Məhsullara qayıt</a>
    <h1>Səbətdəki <span>Məhsullar</span></h1>

    <div id="sebet-items"></div>

    <div class="summary" id="summary-box" style="display:none">
        <div class="summary-row"><span>Məhsullar</span><span id="mehsul-sayi">0 ədəd</span></div>
        <div class="summary-row"><span>Çatdırılma</span><span>Pulsuz</span></div>
        <div class="summary-total">
            <span>Cəmi</span>
            <span id="total-qiymet">0 AZN</span>
        </div>
        <button class="checkout-btn">✅ Sifarişi Tamamla</button>
    </div>
</div>

<script>
    const sebet = JSON.parse(localStorage.getItem('sebet')) || [];
    const container = document.getElementById('sebet-items');
    const summaryBox = document.getElementById('summary-box');

    if (sebet.length === 0) {
        container.innerHTML = `
            <div class="empty-box">
                <p>🛒</p>
                <p>Səbətiniz hazırda boşdur.</p>
            </div>`;
    } else {
        let total = 0;
        let umumi = 0;

        sebet.forEach(m => {
            total += parseFloat(m.qiymet) * m.say;
            umumi += m.say;
            container.innerHTML += `
                <div class="sebet-item">
                    <img src="${m.shekil}" alt="${m.ad}" onerror="this.src='https://via.placeholder.com/80'">
                    <div class="item-info">
                        <h3>${m.ad}</h3>
                        <p>${m.say} ədəd × ${m.qiymet} AZN</p>
                    </div>
                    <div class="item-qiymet">${(parseFloat(m.qiymet) * m.say).toFixed(2)} AZN</div>
                    <button class="sil-btn" onclick="silMehsul('${m.id}')">🗑</button>
                </div>`;
        });

        document.getElementById('total-qiymet').textContent = total.toFixed(2) + ' AZN';
        document.getElementById('mehsul-sayi').textContent = umumi + ' ədəd';
        summaryBox.style.display = 'block';
    }

    function silMehsul(id) {
        let sebet = JSON.parse(localStorage.getItem('sebet')) || [];
        sebet = sebet.filter(m => m.id !== id);
        localStorage.setItem('sebet', JSON.stringify(sebet));
        location.reload();
    }
</script>

</body>
</html>