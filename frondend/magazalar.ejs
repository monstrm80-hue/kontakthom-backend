<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <title>Mağazalar — Kontakt Home</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:#0f0f0f; color:white; font-family:Arial,sans-serif; }
        nav { background:#1a1a1a; padding:0 40px; display:flex; align-items:center; justify-content:space-between; height:65px; position:sticky; top:0; z-index:100; border-bottom:1px solid #2a2a2a; }
        .logo { font-size:22px; font-weight:bold; text-decoration:none; color:white; }
        .logo span { color:#e30613; }
        .nav-links { display:flex; gap:28px; list-style:none; }
        .nav-links a { color:#ccc; text-decoration:none; font-size:15px; transition:color 0.2s; }
        .nav-links a:hover, .nav-links a.active { color:white; }
        .cart-btn { background:#e30613; color:white; padding:9px 20px; border-radius:8px; text-decoration:none; font-weight:bold; font-size:14px; display:flex; align-items:center; gap:8px; }
        .cart-count { background:white; color:#e30613; border-radius:50%; width:20px; height:20px; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:bold; }

        .hero { background:linear-gradient(135deg,#1a1a1a,#111); padding:60px 40px; text-align:center; border-bottom:1px solid #222; }
        .hero h1 { font-size:40px; font-weight:800; margin-bottom:10px; }
        .hero p { color:#888; font-size:16px; }

        .container { max-width:1200px; margin:40px auto; padding:0 24px; }
        .section-title { font-size:22px; font-weight:800; margin-bottom:24px; padding-left:12px; border-left:4px solid #e30613; }

        .search-bar { background:#1a1a1a; border-radius:12px; padding:16px 20px; display:flex; gap:12px; margin-bottom:30px; border:1px solid #2a2a2a; }
        .search-bar input { flex:1; background:#2a2a2a; border:1px solid #333; border-radius:8px; padding:10px 16px; color:white; font-size:15px; }
        .search-bar input::placeholder { color:#555; }
        .search-bar button { background:#e30613; color:white; border:none; padding:10px 24px; border-radius:8px; font-weight:bold; cursor:pointer; }

        .cities-tabs { display:flex; gap:10px; margin-bottom:24px; flex-wrap:wrap; }
        .city-tab { background:#1a1a1a; border:1px solid #2a2a2a; color:#aaa; padding:8px 20px; border-radius:20px; cursor:pointer; font-size:14px; transition:0.2s; }
        .city-tab:hover, .city-tab.active { background:#e30613; border-color:#e30613; color:white; }

        .magazalar-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:18px; }
        .mag-card { background:#1a1a1a; border-radius:14px; padding:22px; border:1px solid #222; transition:border-color 0.2s; display:flex; gap:18px; align-items:flex-start; }
        .mag-card:hover { border-color:#e30613; }
        .mag-icon { background:#e30613; width:50px; height:50px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:22px; flex-shrink:0; }
        .mag-info h3 { font-size:16px; font-weight:700; margin-bottom:6px; }
        .mag-info p { color:#888; font-size:13px; margin-bottom:4px; line-height:1.5; }
        .mag-info .hours { color:#28a745; font-size:13px; font-weight:bold; }
        .mag-info .phone { color:#e30613; font-size:13px; margin-top:6px; }
        .mag-status { display:inline-block; background:#28a74520; color:#28a745; padding:3px 10px; border-radius:10px; font-size:12px; font-weight:bold; margin-top:8px; }

        .stats-bar { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:40px; }
        .stat-box { background:#1a1a1a; border-radius:12px; padding:20px; text-align:center; border:1px solid #222; }
        .stat-box h2 { font-size:32px; font-weight:800; color:#e30613; margin-bottom:6px; }
        .stat-box p { color:#888; font-size:14px; }
    </style>
</head>
<body>

<nav>
    <a href="/" class="logo">Kontakt<span>Home</span></a>
    <ul class="nav-links">
        <li><a href="/">Ana Səhifə</a></li>
        <li><a href="/mehsullar">Məhsullar</a></li>
        <li><a href="/brendler">Brendlər</a></li>
        <li><a href="/kampaniyalar">Kampaniyalar</a></li>
        <li><a href="/magazalar" class="active">Mağazalar</a></li>
        <li><a href="/kreditler">Kredit</a></li>
    </ul>
    <a href="/sebet" class="cart-btn">🛒 Səbət <span class="cart-count" id="cartCount">0</span></a>
</nav>

<div class="hero">
    <h1>Mağazalarımız</h1>
    <p>Azərbaycan boyu 50-dən çox mağazamızda sizi gözləyirik.</p>
</div>

<div class="container">

    <div class="stats-bar">
        <div class="stat-box"><h2>50+</h2><p>Mağaza</p></div>
        <div class="stat-box"><h2>15</h2><p>Şəhər</p></div>
        <div class="stat-box"><h2>09:00</h2><p>Açılış</p></div>
        <div class="stat-box"><h2>22:00</h2><p>Bağlanış</p></div>
    </div>

    <div class="search-bar">
        <input type="text" placeholder="Ünvan axtar...">
        <button>🔍 Axtar</button>
    </div>

    <div class="cities-tabs">
        <div class="city-tab active">Bakı</div>
        <div class="city-tab">Gəncə</div>
        <div class="city-tab">Sumqayıt</div>
        <div class="city-tab">Lənkəran</div>
        <div class="city-tab">Şirvan</div>
        <div class="city-tab">Mingəçevir</div>
    </div>

    <div class="section-title">Bakı Mağazaları</div>
    <div class="magazalar-grid">
        <div class="mag-card">
            <div class="mag-icon">🏪</div>
            <div class="mag-info">
                <h3>Kontakt Home — 28 May</h3>
                <p>📍 Neftçilər prospekti 153, 28 May metro stansiyası yanı</p>
                <div class="hours">⏰ 09:00 – 22:00 (Hər gün)</div>
                <div class="phone">📞 *7777</div>
                <span class="mag-status">✓ Açıqdır</span>
            </div>
        </div>
        <div class="mag-card">
            <div class="mag-icon">🏪</div>
            <div class="mag-info">
                <h3>Kontakt Home — Gənclik Mall</h3>
                <p>📍 Gənclik Mall, 3-cü mərtəbə, Gənclik metro yanı</p>
                <div class="hours">⏰ 10:00 – 22:00 (Hər gün)</div>
                <div class="phone">📞 *7777</div>
                <span class="mag-status">✓ Açıqdır</span>
            </div>
        </div>
        <div class="mag-card">
            <div class="mag-icon">🏪</div>
            <div class="mag-info">
                <h3>Kontakt Home — Port Baku</h3>
                <p>📍 Port Baku Mall, Neftçilər pr. 153A</p>
                <div class="hours">⏰ 10:00 – 22:00 (Hər gün)</div>
                <div class="phone">📞 *7777</div>
                <span class="mag-status">✓ Açıqdır</span>
            </div>
        </div>
        <div class="mag-card">
            <div class="mag-icon">🏪</div>
            <div class="mag-info">
                <h3>Kontakt Home — Xətai</h3>
                <p>📍 Xətai prospekti 32, Xətai rayonu</p>
                <div class="hours">⏰ 09:00 – 21:00 (Hər gün)</div>
                <div class="phone">📞 *7777</div>
                <span class="mag-status">✓ Açıqdır</span>
            </div>
        </div>
        <div class="mag-card">
            <div class="mag-icon">🏪</div>
            <div class="mag-info">
                <h3>Kontakt Home — Nizami</h3>
                <p>📍 Nizami küçəsi 72, Şəhər mərkəzi</p>
                <div class="hours">⏰ 09:00 – 22:00 (Hər gün)</div>
                <div class="phone">📞 *7777</div>
                <span class="mag-status">✓ Açıqdır</span>
            </div>
        </div>
        <div class="mag-card">
            <div class="mag-icon">🏪</div>
            <div class="mag-info">
                <h3>Kontakt Home — Binə</h3>
                <p>📍 Binə şəhərciyindəki Kontakt mağazası</p>
                <div class="hours">⏰ 09:00 – 21:00 (Hər gün)</div>
                <div class="phone">📞 *7777</div>
                <span class="mag-status">✓ Açıqdır</span>
            </div>
        </div>
    </div>
</div>

<script>
function cartSayiYenile() {
    const sebet = JSON.parse(localStorage.getItem('sebet')) || [];
    const umumi = sebet.reduce((c, m) => c + m.say, 0);
    document.getElementById('cartCount').textContent = umumi;
}
cartSayiYenile();

document.querySelectorAll('.city-tab').forEach(tab => {
    tab.addEventListener('click', function() {
        document.querySelectorAll('.city-tab').forEach(t => t.classList.remove('active'));
        this.classList.add('active');
    });
});
</script>
</body>
</html>
