<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mağazalarımız — Kontakt Home</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #0b0b0c;
            color: #ffffff;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* --- MENYU (NAVBAR) --- */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 8%;
            background-color: #0b0b0c;
            border-bottom: 1px solid #1a1a1c;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #ff0022;
            letter-spacing: 1px;
        }

        .logo span {
            color: #ffffff;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 30px;
        }

        .nav-links li a {
            font-size: 15px;
            font-weight: 500;
            color: #b3b3b3;
            transition: color 0.3s ease;
        }

        .nav-links li a:hover, .nav-links li.active a {
            color: #ff0022;
        }

        .nav-right {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .icon-btn {
            background: none;
            border: none;
            color: white;
            font-size: 18px;
            cursor: pointer;
            transition: color 0.3s;
        }

        .icon-btn:hover {
            color: #ff0022;
        }

        .cart-btn {
            background-color: #ff0022;
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: transform 0.3s, background-color 0.3s;
        }

        .cart-btn:hover {
            background-color: #cc001b;
            transform: translateY(-2px);
        }

        /* --- SƏHİFƏ BAŞLIĞI --- */
        .page-header {
            text-align: center;
            padding: 60px 20px 40px 20px;
            background: linear-gradient(180deg, #111113 0%, #0b0b0c 100%);
        }

        .page-header h1 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: -1px;
        }

        .page-header span {
            color: #ff0022;
        }

        .page-header p {
            color: #88888b;
            font-size: 16px;
            max-width: 600px;
            margin: 0 auto;
        }

        /* --- FILTR HISSƏSİ --- */
        .filter-section {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px 4%;
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            justify-content: center;
            margin-bottom: 40px;
        }

        .filter-btn {
            background-color: #111113;
            border: 1px solid #1a1a1c;
            color: #a0a0a5;
            padding: 10px 20px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .filter-btn:hover, .filter-btn.active {
            background-color: #ff0022;
            border-color: #ff0022;
            color: white;
            box-shadow: 0 5px 15px rgba(255, 0, 34, 0.2);
        }

        /* --- ƏSAS KONTEYNER --- */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 4% 80px 4%;
        }

        /* --- MAĞAZALAR GRID --- */
        .stores-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 30px;
        }

        /* --- MAĞAZA KARTI --- */
        .store-card {
            background-color: #111113;
            border: 1px solid #1a1a1c;
            border-radius: 20px;
            padding: 30px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        }

        .store-card:hover {
            transform: translateY(-5px);
            border-color: #ff0022;
            box-shadow: 0 10px 25px rgba(255, 0, 34, 0.1);
        }

        .store-status {
            display: inline-block;
            align-self: flex-start;
            background-color: rgba(0, 204, 102, 0.1);
            color: #00cc66;
            padding: 4px 12px;
            font-size: 12px;
            font-weight: 600;
            border-radius: 30px;
            margin-bottom: 15px;
            text-transform: uppercase;
        }

        .store-name {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 15px;
            color: #ffffff;
        }

        .store-info-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 30px;
        }

        .store-info-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 14px;
            color: #a0a0a5;
            line-height: 1.5;
        }

        .store-info-item .icon {
            color: #ff0022;
            font-size: 16px;
            flex-shrink: 0;
        }

        /* Xəritədə Bax Düyməsi */
        .map-btn {
            width: 100%;
            background-color: transparent;
            border: 1px solid #2a2a2e;
            color: #ffffff;
            padding: 12px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

        .store-card:hover .map-btn {
            background-color: #ffffff;
            border-color: #ffffff;
            color: #0b0b0c;
        }

        /* --- FOOTER --- */
        footer {
            background-color: #0b0b0c;
            border-top: 1px solid #1a1a1c;
            padding: 40px 8%;
            text-align: center;
            color: #555558;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <nav>
        <a href="/" class="logo">Kontakt<span>Home</span></a>
        <ul class="nav-links">
            <li><a href="/">Ana Səhifə</a></li>
            <li><a href="/mehsullar">Məhsullar</a></li>
            <li><a href="/brendler">Brendlər</a></li>
