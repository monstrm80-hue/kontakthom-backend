<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Məhsullar — Kontakt Home</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #0f0f0f; color: white; font-family: Arial, sans-serif; min-height: 100vh; }
        nav { background: #1a1a1a; padding: 0 40px; display: flex; align-items: center; justify-content: space-between; height: 65px; position: sticky; top: 0; z-index: 100; border-bottom: 1px solid #2a2a2a; }
        .logo { font-size: 22px; font-weight: bold; text-decoration: none; color: white; }
        .logo span { color: #e30613; }
        .nav-links { display: flex; gap: 28px; list-style: none; }
        .nav-links a { color: #ccc; text-decoration: none; font-size: 15px; transition: color 0.2s; }
        .nav-links a:hover { color: white; }
        .nav-right { display: flex; align-items: center; gap: 16px; }
        .cart-btn { background: #e30613; color: white; padding: 9px 20px; border-radius: 8px; text-decoration: none; font-weight: bold; font-size: 14px; display: flex; align-items: center; gap: 8px; }
        .cart-count { background: white; color: #e30613; border-radius: 50%; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: bold; }
        .page-hero { background: linear-gradient(135deg, #1a1a1a 0%, #111 100%); padding: 50px 40px; text-align: center; border-bottom: 1px solid #222; }
        .page-hero h1 { font-size: 38px; font-weight: 800; margin-bottom: 10px; }
        .page-hero p { color: #888; font-size: 16px; max-width: 600px; margin: 0 auto; }
        .main-layout { display: flex; max-width: 1300px; margin: 30px auto; gap: 28px; padding: 0 24px; }
        .sidebar { width: 240px; flex-shrink: 0; }
        .sidebar-box { background: #1a1a1a; border-radius: 12px; padding: 20px; margin-bottom: 16px; }
        .sidebar-box h3 { font-size: 15px; font-weight: 700; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 2px solid #e30613; display: inline-block; }
        .category-item { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid #2a2a2a; cursor: pointer; color: #ccc; font-size: 14px; transition: color 0.2s; }
        .category-item:hover { color: white; }
        .category-item:last-child { border: none; }
        .cat-count { background: #2a2a2a; color: #888; font-size: 12px; padding: 2px 8px; border-radius: 10px; }
        .price-inputs { display: flex; gap: 8px; margin-bottom: 10px; }
        .price-inputs input { width: 100%; padding: 9px; background: #2a2a2a; border: 1px solid #333; border-radius: 6px; color: white; font-size: 13px; }
        .filter-btn { width: 100%; padding: 10px; background: #e30613; color: white; border: none; border-radius: 8px; font-size: 14px; font-weight: bold; cursor: pointer; }
        .filter-btn:hover { background: #c0000f; }
        .products-area { flex: 1; }
        .products-toolbar { display: flex; justify-content: space-between; align-items: center; background: #1a1a1a; border-radius: 10px; padding: 12px 18px; margin-bottom: 20px; font-size: 14px; color: #aaa; }
        .products-toolbar select { background: #2a2a2a; border: 1px solid #333; color: white; padding: 6px 12px; border-radius: 6px; font-size: 14px; }
        .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
        .product-card { background: #1a1a1a; border-radius: 14px; overflow: hidden; position: relative; border: 1px solid #222; transition: transform 0.2s, border-color 0.2s; }
        .product-card:hover { transform: translateY(-4px); border-color: #e30613; }
        .badge { position: absolute; top: 12px; left: 12px; background: #e30613; color: white; font-size: 11px; font-weight: bold; padding: 4px 10px; border-radius: 6px; z-index: 2; }
        .fav-btn { position: absolute; top: 10px; right: 10px; background: #2a2a2a; border: none; color: #888; width: 34px; height: 34px; border-radius: 50%; font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: 0.2s; z-index: 2; }
        .fav-btn:hover { background: #e30613; color: white; }
        .card-img { background: #222; height: 180px; display: flex; align-items: center; justify-content: center; overflow: hidden; }
        .card-img img { max-height: 160px; max-width: 90%; object-fit: contain; transition: transform 0.3s; }
        .product-card:hover .card-img img { transform: scale(1.05); }
        .card-body { padding: 14px; }
        .brend { color: #e30613; font-size: 11px; font-weight: 700; letter-spacing: 1px; margin-bottom: 6px; }
        .card-body h3 { font-size: 14px; font-weight: 600; line-height: 1.4; margin-bottom: 8px; color: #eee; min-height: 40px; }
        .stars { color: #f5a623; font-size: 13px; margin-bottom: 10px; }
        .qiymet-box { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .qiymet { font-size: 20px; font-weight: 800; color: white; }
        .eski { font-size: 13px; color: #666; text-decoration: line-through; }
        .kredit-info { background: #111; border: 1px solid #333; border-radius: 6px; padding: 6px 10px; font-size: 12px; color: #e30613; margin-bottom: 12px; text-align: center; }
        .add-to-cart { width: 100%; padding: 11px; background: #e30613; color: white; font-size: 14px; font-weight: bold; border: none; border-radius: 8px; cursor: pointer; transition: background 0.2s; }
        .add-to-cart:hover { background: #c0000f; }
        .empty-products { text-align: center; padding: 80px 20px; color: #555; grid-column: 1 / -1; }
        .empty-products p:first-child { font-size: 50px; margin-bottom: 16px; }
        .empty-products a { display: inline-block; margin-top: 16px; background: #e30613; color: white; padding: 10px 24px; border-radius: 8px; text-decoration: none; font-weight: bold; }
    </style>
</head>
<body>

<nav>
    <a href="/" class="logo">Kontakt<span>Home</span></a>
    <ul class="nav-links">
        <li><a href="/">Ana Səhifə</a></li>
        <li><a href="/mehsullar">Məhsullar</a></li>
        <li><a href="/brendler">Brendlər</a></li>
        <li><a href="/kampaniyalar">Kampaniyalar</a></li>
        <li><a href="/magazalar">Mağazalar</a></li>
        <li><a href="/kreditler">Kredit</a></li>
    </ul>
    <div class="nav-right">
        <a href="/sebet" class="cart-btn">
            🛒 Səbət
            <span class="cart-count" id="cartCount">0</span>
        </a>
    </div>
</nav>

<div class="page-hero">
    <h1>Bütün Məhsullar</h1>
    <p>Ən son texnologiyalar, smartfonlar və meişət texnikası sərfəli şərtlərlə yalnız Kontakt Home-da.</p>
</div>

<div class="main-layout">
    <div class="sidebar">
        <div class="sidebar-box">
            <h3>Kateqoriyalar</h3>
            <div class="category-item"><span>Smartfonlar</span><span class="cat-count">142</span></div>
            <div class="category-item"><span>Noutbuklar</span><span class="cat-count">85</span></div>
            <div class="category-item"><span>Televizorlar</span><span class="cat-count">64</span></div>
            <div class="category-item"><span>Meişət Texnikası</span><span class="cat-count">210</span></div>
            <div class="category-item"><span>Smart Saatlar</span><span class="cat-count">53</span></div>
            <div class="category-item"><span>Aksesuarlar</span><span class="cat-count">412</span></div>
        </div>
        <div class="sidebar-box">
            <h3>Qiymət (AZN)</h3>
            <div class="price-inputs">
                <input type="number" placeholder="Min" id="minPrice">
                <input type="number" placeholder="Max" id="maxPrice">
            </div>
            <button class="filter-btn">Filtrələ</button>
        </div>
        <div class="sidebar-box">
            <h3>Brend</h3>
            <div class="category-item"><span>Apple</span><span class="cat-count">45</span></div>
            <div class="category-item"><span>Samsung</span><span class="cat-count">82</span></div>
            <div class="category-item"><span>Xiaomi</span><span class="cat-count">61</span></div>
            <div class="category-item"><span>Asus</span><span class="cat-count">24</span></div>
            <div class="category-item"><span>LG</span><span class="cat-count">33</span></div>
        </div>
    </div>

    <div class="products-area">
        <div class="products-toolbar">
            <span>Toplam <strong><%= mehsullar.length %></strong> məhsul göstərilir</span>
            <select>
                <option>Sıralama: Ən yenilər</option>
                <option>Qiymət: Artan</option>
                <option>Qiymət: Azalan</option>
            </select>
        </div>

        <div class="products-grid">
            <% if (mehsullar.length === 0) { %>
                <div class="empty-products">
                    <p>📦</p>
                    <p>Hələ məhsul əlavə edilməyib.</p>
                    <a href="/admin">Admin paneldən əlavə et</a>
                </div>
            <% } else { %>
                <% mehsullar.forEach(function(m) { %>
                <div class="product-card">
                    <% if (m.populyar) { %>
                        <span class="badge">POPULYAR</span>
                    <% } %>
                    <button class="fav-btn">♡</button>
                    <div class="card-img">
                        <% if (m.shekil) { %>
                            <img src="<%= m.shekil %>" alt="<%= m.ad %>">
                        <% } else { %>
                            <span style="color:#444; font-size:40px;">📷</span>
                        <% } %>
                    </div>
                    <div class="card-body">
                        <p class="brend"><%= m.brend ? m.brend.toUpperCase() : '' %></p>
                        <h3><%= m.ad %></h3>
                        <div class="stars">★★★★★</div>
                        <div class="qiymet-box">
                            <span class="qiymet"><%= m.qiymet %> AZN</span>
                            <% if (m.eskiQiymet) { %>
                                <span class="eski"><%= m.eskiQiymet %> AZN</span>
                            <% } %>
                        </div>
                        <% if (m.kredit) { %>
                            <div class="kredit-info"><%= m.kredit %></div>
                        <% } %>
                        <button class="add-to-cart"
                            data-id="<%= m._id %>"
                            data-ad="<%= m.ad %>"
                            data-qiymet="<%= m.qiymet %>"
                            data-shekil="<%= m.shekil || '' %>">
                            Səbətə at
                        </button>
                    </div>
                </div>
                <% }) %>
            <% } %>
        </div>
    </div>
</div>

<script>
function cartSayiYenile() {
    const sebet = JSON.parse(localStorage.getItem('sebet')) || [];
    const umumi = sebet.reduce((c, m) => c + m.say, 0);
    document.getElementById('cartCount').textContent = umumi;
}
cartSayiYenile();

document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', function() {
        const mehsul = {
            id: this.dataset.id,
            ad: this.dataset.ad,
            qiymet: this.dataset.qiymet,
            shekil: this.dataset.shekil,
            say: 1
        };
        let sebet = JSON.parse(localStorage.getItem('sebet')) || [];
        const movcud = sebet.findIndex(m => m.id === mehsul.id);
        if (movcud >= 0) {
            sebet[movcud].say += 1;
        } else {
            sebet.push(mehsul);
        }
        localStorage.setItem('sebet', JSON.stringify(sebet));
        cartSayiYenile();
        this.textContent = '✓ Əlavə edildi!';
        this.style.background = '#28a745';
        setTimeout(() => {
            this.textContent = 'Səbətə at';
            this.style.background = '#e30613';
        }, 1500);
    });
});
</script>

</body>
</html>