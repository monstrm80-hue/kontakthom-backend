<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <title>Kredit — Kontakt Home</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:#0f0f0f; color:white; font-family:Arial,sans-serif; }
        nav { background:#1a1a1a; padding:0 40px; display:flex; align-items:center; justify-content:space-between; height:65px; position:sticky; top:0; z-index:100; border-bottom:1px solid #2a2a2a; }
        .logo { font-size:22px; font-weight:bold; text-decoration:none; color:white; }
        .logo span { color:#e30613; }
        .nav-links { display:flex; gap:28px; list-style:none; }
        .nav-links a { color:#ccc; text-decoration:none; font-size:15px; transition:color 0.2s; }
        .nav-links a:hover, .nav-links a.active { color:white; }
        .cart-btn { background:#e30613; color:white; padding:9px 20px; border-radius:8px; text-decoration:none; font-weight:bold; font-size:14px; display:flex; align-items:center; gap:8px; }
        .cart-count { background:white; color:#e30613; border-radius:50%; width:20px; height:20px; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:bold; }

        .hero { background:linear-gradient(135deg,#0a0a1a,#111); padding:60px 40px; text-align:center; border-bottom:1px solid #222; position:relative; overflow:hidden; }
        .hero::before { content:'💳'; position:absolute; font-size:200px; opacity:0.04; top:-20px; left:5%; }
        .hero h1 { font-size:40px; font-weight:800; margin-bottom:10px; }
        .hero h1 span { color:#e30613; }
        .hero p { color:#888; font-size:16px; }

        .container { max-width:1100px; margin:40px auto; padding:0 24px; }
        .section-title { font-size:22px; font-weight:800; margin-bottom:24px; padding-left:12px; border-left:4px solid #e30613; }

        .kredit-cards { display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-bottom:50px; }
        .k-card { background:#1a1a1a; border-radius:16px; padding:28px; border:1px solid #222; transition:transform 0.2s, border-color 0.2s; text-align:center; }
        .k-card:hover { transform:translateY(-4px); border-color:#e30613; }
        .k-card.popular { border-color:#e30613; background:#1a0000; }
        .popular-badge { background:#e30613; color:white; font-size:12px; font-weight:bold; padding:4px 14px; border-radius:10px; display:inline-block; margin-bottom:14px; }
        .k-card h3 { font-size:20px; font-weight:800; margin-bottom:8px; }
        .k-card .muddet { font-size:40px; font-weight:900; color:#e30613; margin:12px 0; }
        .k-card .muddet span { font-size:16px; color:#888; font-weight:400; }
        .k-card ul { list-style:none; margin:16px 0; text-align:left; }
        .k-card ul li { padding:8px 0; border-bottom:1px solid #2a2a2a; color:#ccc; font-size:14px; display:flex; gap:8px; }
        .k-card ul li::before { content:'✓'; color:#28a745; font-weight:bold; }
        .k-card ul li:last-child { border:none; }
        .k-btn { display:block; background:#e30613; color:white; padding:12px; border-radius:10px; text-decoration:none; font-weight:bold; font-size:15px; margin-top:16px; transition:background 0.2s; }
        .k-btn:hover { background:#c0000f; }
        .k-btn.ghost { background:transparent; border:2px solid #e30613; color:#e30613; }
        .k-btn.ghost:hover { background:#e30613; color:white; }

        .hesabla-box { background:#1a1a1a; border-radius:16px; padding:36px; border:1px solid #222; margin-bottom:50px; }
        .hesabla-box h2 { font-size:22px; font-weight:800; margin-bottom:24px; }
        .hesabla-form { display:grid; grid-template-columns:1fr 1fr; gap:20px; }
        .form-group label { display:block; color:#888; font-size:13px; margin-bottom:8px; }
        .form-group input, .form-group select {
            width:100%; padding:12px 16px; background:#2a2a2a; border:1px solid #333; border-radius:8px; color:white; font-size:15px;
        }
        .hesabla-btn { grid-column:1/-1; background:#e30613; color:white; padding:14px; border:none; border-radius:10px; font-size:16px; font-weight:bold; cursor:pointer; transition:background 0.2s; }
        .hesabla-btn:hover { background:#c0000f; }
        .netice { grid-column:1/-1; background:#111; border-radius:12px; padding:20px; border:1px solid #2a2a2a; display:none; }
        .netice h3 { color:#e30613; font-size:18px; margin-bottom:12px; }
        .netice-row { display:flex; justify-content:space-between; padding:8px 0; border-bottom:1px solid #222; color:#ccc; font-size:14px; }
        .netice-row:last-child { border:none; font-weight:bold; color:white; font-size:16px; }

        .banks-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:40px; }
        .bank-card { background:#1a1a1a; border-radius:12px; padding:20px; text-align:center; border:1px solid #222; transition:border-color 0.2s; }
        .bank-card:hover { border-color:#e30613; }
        .bank-icon { font-size:32px; margin-bottom:10px; }
        .bank-card h4 { font-size:14px; font-weight:700; margin-bottom:4px; }
        .bank-card p { color:#888; font-size:12px; }

        .steps { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:40px; }
        .step { background:#1a1a1a; border-radius:12px; padding:20px; text-align:center; border:1px solid #222; }
        .step-num { width:40px; height:40px; background:#e30613; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:18px; font-weight:900; margin:0 auto 12px; }
        .step h4 { font-size:14px; font-weight:700; margin-bottom:6px; }
        .step p { color:#888; font-size:13px; }
    </style>
</head>
<body>

<nav>
    <a href="/" class="logo">Kontakt<span>Home</span></a>
    <ul class="nav-links">
        <li><a href="/">Ana Səhifə</a></li>
        <li><a href="/mehsullar">Məhsullar</a></li>
        <li><a href="/brendler">Brendlər</a></li>
        <li><a href="/kampaniyalar">Kampaniyalar</a></li>
        <li><a href="/magazalar">Mağazalar</a></li>
        <li><a href="/kreditler" class="active">Kredit</a></li>
    </ul>
    <a href="/sebet" class="cart-btn">🛒 Səbət <span class="cart-count" id="cartCount">0</span></a>
</nav>

<div class="hero">
    <h1>Faizsiz <span>Kredit</span> Şərtləri</h1>
    <p>İstədiyin məhsulu al, rahatlıqla ödə — heç bir gizli ödəniş yoxdur.</p>
</div>

<div class="container">

    <div class="section-title" style="margin-top:40px;">Kredit Planları</div>
    <div class="kredit-cards">
        <div class="k-card">
            <h3>Standart</h3>
            <div class="muddet">6 <span>ay</span></div>
            <ul>
                <li>Faizsiz ödəniş</li>
                <li>İlkin ödəniş yoxdur</li>
                <li>Sürətli təsdiq</li>
                <li>Minimum sənəd</li>
            </ul>
            <a href="/mehsullar" class="k-btn ghost">Məhsul Seç</a>
        </div>
        <div class="k-card popular">
            <span class="popular-badge">🔥 Ən Populyar</span>
            <h3>Optimal</h3>
            <div class="muddet">12 <span>ay</span></div>
            <ul>
                <li>Faizsiz ödəniş</li>
                <li>İlkin ödəniş yoxdur</li>
                <li>Ani təsdiq</li>
                <li>Yalnız şəxsiyyət vəsiqəsi</li>
            </ul>
            <a href="/mehsullar" class="k-btn">Məhsul Seç</a>
        </div>
        <div class="k-card">
            <h3>Uzunmüddətli</h3>
            <div class="muddet">24 <span>ay</span></div>
            <ul>
                <li>Minimal faiz</li>
                <li>10% ilkin ödəniş</li>
                <li>Geniş məbləğ limiti</li>
                <li>Çevik ödəniş</li>
            </ul>
            <a href="/mehsullar" class="k-btn ghost">Məhsul Seç</a>
        </div>
    </div>

    <div class="section-title">Kredit Kalkulyatoru</div>
    <div class="hesabla-box">
        <h2>💰 Aylıq ödənişi hesabla</h2>
        <div class="hesabla-form">
            <div class="form-group">
                <label>Məhsul qiyməti (AZN)</label>
                <input type="number" id="qiymet" placeholder="2499">
            </div>
            <div class="form-group">
                <label>Müddət</label>
                <select id="muddet">
                    <option value="6">6 ay</option>
                    <option value="12" selected>12 ay</option>
                    <option value="18">18 ay</option>
                    <option value="24">24 ay</option>
                </select>
            </div>
            <button class="hesabla-btn" onclick="hesabla()">Hesabla</button>
            <div class="netice" id="netice">
                <h3>📊 Hesablama Nəticəsi</h3>
                <div class="netice-row"><span>Məhsul qiyməti</span><span id="r-qiymet">—</span></div>
                <div class="netice-row"><span>Müddət</span><span id="r-muddet">—</span></div>
                <div class="netice-row"><span>Aylıq ödəniş</span><span id="r-aylik">—</span></div>
            </div>
        </div>
    </div>

    <div class="section-title">Tərəfdaş Banklar</div>
    <div class="banks-grid">
        <div class="bank-card"><div class="bank-icon">🏦</div><h4>Kapital Bank</h4><p>6–24 ay</p></div>
        <div class="bank-card"><div class="bank-icon">🏦</div><h4>ABB Bank</h4><p>6–18 ay</p></div>
        <div class="bank-card"><div class="bank-icon">🏦</div><h4>PAŞA Bank</h4><p>12–24 ay</p></div>
        <div class="bank-card"><div class="bank-icon">🏦</div><h4>Xalq Bank</h4><p>6–12 ay</p></div>
    </div>

    <div class="section-title">Necə Almaq Olar?</div>
    <div class="steps">
        <div class="step"><div class="step-num">1</div><h4>Məhsul Seç</h4><p>Saytdan və ya mağazadan istədiyin məhsulu seç</p></div>
        <div class="step"><div class="step-num">2</div><h4>Kredit Planı</h4><p>Sənə uyğun kredit müddətini seç</p></div>
        <div class="step"><div class="step-num">3</div><h4>Sənəd Ver</h4><p>Yalnız şəxsiyyət vəsiqəsi lazımdır</p></div>
        <div class="step"><div class="step-num">4</div><h4>Al və Get!</h4><p>Ani təsdiq — məhsulunu dərhal götür</p></div>
    </div>
</div>

<script>
function cartSayiYenile() {
    const sebet = JSON.parse(localStorage.getItem('sebet')) || [];
    const umumi = sebet.reduce((c, m) => c + m.say, 0);
    document.getElementById('cartCount').textContent = umumi;
}
cartSayiYenile();

function hesabla() {
    const qiymet = parseFloat(document.getElementById('qiymet').value);
    const muddet = parseInt(document.getElementById('muddet').value);
    if (!qiymet || qiymet <= 0) { alert('Zəhmət olmasa qiymet daxil edin'); return; }
    const aylik = (qiymet / muddet).toFixed(2);
    document.getElementById('r-qiymet').textContent = qiymet + ' AZN';
    document.getElementById('r-muddet').textContent = muddet + ' ay';
    document.getElementById('r-aylik').textContent = aylik + ' AZN';
    document.getElementById('netice').style.display = 'block';
}
</script>
</body>
</html>
