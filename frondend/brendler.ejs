<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <title>Brendlər — Kontakt Home</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { background:#0f0f0f; color:white; font-family:Arial,sans-serif; }
        nav { background:#1a1a1a; padding:0 40px; display:flex; align-items:center; justify-content:space-between; height:65px; position:sticky; top:0; z-index:100; border-bottom:1px solid #2a2a2a; }
        .logo { font-size:22px; font-weight:bold; text-decoration:none; color:white; }
        .logo span { color:#e30613; }
        .nav-links { display:flex; gap:28px; list-style:none; }
        .nav-links a { color:#ccc; text-decoration:none; font-size:15px; transition:color 0.2s; }
        .nav-links a:hover, .nav-links a.active { color:white; }
        .cart-btn { background:#e30613; color:white; padding:9px 20px; border-radius:8px; text-decoration:none; font-weight:bold; font-size:14px; display:flex; align-items:center; gap:8px; }
        .cart-count { background:white; color:#e30613; border-radius:50%; width:20px; height:20px; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:bold; }

        .hero { background:linear-gradient(135deg,#1a1a1a,#111); padding:60px 40px; text-align:center; border-bottom:1px solid #222; }
        .hero h1 { font-size:40px; font-weight:800; margin-bottom:10px; }
        .hero p { color:#888; font-size:16px; }

        .container { max-width:1200px; margin:40px auto; padding:0 24px; }
        .section-title { font-size:22px; font-weight:800; margin-bottom:24px; padding-left:12px; border-left:4px solid #e30613; }

        .brands-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:16px; margin-bottom:50px; }
        .brand-card { background:#1a1a1a; border-radius:14px; padding:28px 16px; text-align:center; border:1px solid #222; transition:transform 0.2s, border-color 0.2s; cursor:pointer; text-decoration:none; color:white; display:block; }
        .brand-card:hover { transform:translateY(-4px); border-color:#e30613; }
        .brand-icon { width:64px; height:64px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:26px; font-weight:900; margin:0 auto 14px; }
        .brand-card h3 { font-size:16px; font-weight:700; margin-bottom:4px; }
        .brand-card p { color:#888; font-size:13px; }

        .ic-apple { background:linear-gradient(135deg,#555,#222); color:white; }
        .ic-samsung { background:linear-gradient(135deg,#1428a0,#0a1560); color:white; }
        .ic-xiaomi { background:linear-gradient(135deg,#e30613,#8b0000); color:white; }
        .ic-asus { background:linear-gradient(135deg,#00b4d8,#0077b6); color:white; }
        .ic-lg { background:linear-gradient(135deg,#a50034,#5c001d); color:white; }
        .ic-sony { background:linear-gradient(135deg,#333,#111); color:white; }
        .ic-lenovo { background:linear-gradient(135deg,#e2231a,#8b0000); color:white; }
        .ic-huawei { background:linear-gradient(135deg,#cf0a2c,#7a0019); color:white; }
        .ic-philips { background:linear-gradient(135deg,#0066a1,#003d61); color:white; }
        .ic-bosch { background:linear-gradient(135deg,#007bc0,#004a75); color:white; }

        .promo-banner { background:linear-gradient(135deg,#1a1a1a,#2a2a2a); border:1px solid #333; border-radius:16px; padding:36px 40px; display:flex; justify-content:space-between; align-items:center; margin-bottom:40px; }
        .promo-banner h2 { font-size:24px; font-weight:800; margin-bottom:8px; }
        .promo-banner h2 span { color:#e30613; }
        .promo-banner p { color:#888; font-size:14px; }
        .promo-banner a { display:inline-block; background:#e30613; color:white; padding:12px 28px; border-radius:10px; text-decoration:none; font-weight:bold; white-space:nowrap; }
        .promo-banner a:hover { background:#c0000f; }
    </style>
</head>
<body>

<nav>
    <a href="/" class="logo">Kontakt<span>Home</span></a>
    <ul class="nav-links">
        <li><a href="/">Ana Səhifə</a></li>
        <li><a href="/mehsullar">Məhsullar</a></li>
        <li><a href="/brendler" class="active">Brendlər</a></li>
        <li><a href="/kampaniyalar">Kampaniyalar</a></li>
        <li><a href="/magazalar">Mağazalar</a></li>
        <li><a href="/kreditler">Kredit</a></li>
    </ul>
    <a href="/sebet" class="cart-btn">🛒 Səbət <span class="cart-count" id="cartCount">0</span></a>
</nav>

<div class="hero">
    <h1>Partnyor Brendlərimiz</h1>
    <p>Dünyanın ən qabaqcıl və etibarlı istehsalçılarının rəsmi məhsulları bir məkanda.</p>
</div>

<div class="container">

    <div class="promo-banner">
        <div>
            <h2>Orijinal məhsul, <span>rəsmi zəmanət</span></h2>
            <p>Bütün brendlərin məhsulları orijinal, rəsmi zəmanətli və sərfəli kredit şərtləri ilə.</p>
        </div>
        <a href="/mehsullar">Məhsullara bax →</a>
    </div>

    <div class="section-title">Bütün Brendlər</div>
    <div class="brands-grid">
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-apple">🍎</div>
            <h3>Apple</h3>
            <p>45 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-samsung">S</div>
            <h3>Samsung</h3>
            <p>82 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-xiaomi">X</div>
            <h3>Xiaomi</h3>
            <p>61 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-asus">A</div>
            <h3>Asus</h3>
            <p>24 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-lg">L</div>
            <h3>LG</h3>
            <p>33 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-sony">S</div>
            <h3>Sony</h3>
            <p>18 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-lenovo">L</div>
            <h3>Lenovo</h3>
            <p>29 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-huawei">H</div>
            <h3>Huawei</h3>
            <p>22 məhsul</p>
        </a>
        <a href="/mehsullar" class="brand-card">
            <div class="brand-icon ic-philips">P</div>
            <h3>Philips</h3>
            <p>41 məhsul</p>
        </a>
        <a href="/mehsullan" class="brand-card">
            <div class="brand-icon ic-bosch">B</div>
            <h3>Bosch</h3>
            <p>37 məhsul</p>
        </a>
    </div>
</div>

<script>
function cartSayiYenile() {
    const sebet = JSON.parse(localStorage.getItem('sebet')) || [];
    const umumi = sebet.reduce((c, m) => c + m.say, 0);
    document.getElementById('cartCount').textContent = umumi;
}
cartSayiYenile();
</script>
</body>
</html>
