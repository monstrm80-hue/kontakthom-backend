<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Brendlər — Kontakt Home</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #0b0b0c;
            color: #ffffff;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        /* --- MENYU (NAVBAR) --- */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 8%;
            background-color: #0b0b0c;
            border-bottom: 1px solid #1a1a1c;
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #ff0022;
            letter-spacing: 1px;
        }

        .logo span {
            color: #ffffff;
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 30px;
        }

        .nav-links li a {
            font-size: 15px;
            font-weight: 500;
            color: #b3b3b3;
            transition: color 0.3s ease;
        }

        .nav-links li a:hover, .nav-links li.active a {
            color: #ff0022;
        }

        .nav-right {
            display: flex;
            gap: 20px;
            align-items: center;
        }

        .icon-btn {
            background: none;
            border: none;
            color: white;
            font-size: 18px;
            cursor: pointer;
            transition: color 0.3s;
        }

        .icon-btn:hover {
            color: #ff0022;
        }

        .cart-btn {
            background-color: #ff0022;
            color: white;
            padding: 10px 20px;
            border-radius: 25px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: transform 0.3s, background-color 0.3s;
        }

        .cart-btn:hover {
            background-color: #cc001b;
            transform: translateY(-2px);
        }

        /* --- SƏHİFƏ BAŞLIĞI --- */
        .page-header {
            text-align: center;
            padding: 60px 20px 40px 20px;
            background: linear-gradient(180deg, #111113 0%, #0b0b0c 100%);
        }

        .page-header h1 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 15px;
            letter-spacing: -1px;
        }

        .page-header p {
            color: #88888b;
            font-size: 16px;
            max-width: 600px;
            margin: 0 auto;
        }

        /* --- ƏSAS KONTEYNER --- */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 4% 80px 4%;
        }

        /* --- AXTARIŞ PANELİ --- */
        .search-bar-wrapper {
            margin-bottom: 40px;
            display: flex;
            justify-content: center;
        }

        .brand-search-input {
            width: 100%;
            max-width: 500px;
            background-color: #111113;
            border: 1px solid #1a1a1c;
            padding: 15px 25px;
            border-radius: 30px;
            color: white;
            font-size: 15px;
            outline: none;
            transition: border-color 0.3s;
        }

        .brand-search-input:focus {
            border-color: #ff0022;
        }

        /* --- BREND GRID SİSTEMİ --- */
        .brands-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 25px;
        }

        /* --- BREND KARTI --- */
        .brand-card {
            background-color: #111113;
            border: 1px solid #1a1a1c;
            border-radius: 16px;
            padding: 30px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
        }

        .brand-card:hover {
            transform: translateY(-5px);
            border-color: #ff0022;
            box-shadow: 0 10px 20px rgba(255, 0, 34, 0.1);
        }

        /* Placeholder Loqo qutusu */
        .brand-logo-placeholder {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #1e1e21 0%, #161619 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: 700;
            color: #ff0022;
            margin-bottom: 15px;
            border: 1px solid #2a2a2e;
        }

        .brand-card:hover .brand-logo-placeholder {
            background: #ff0022;
            color: white;
            border-color: #ff0022;
        }

        .brand-name {
            font-size: 18px;
            font-weight: 600;
            color: #ffffff;
            margin-bottom: 5px;
        }

        .brand-count {
            font-size: 13px;
            color: #666669;
        }

        /* --- FOOTER --- */
        footer {
            background-color: #0b0b0c;
            border-top: 1px solid #1a1a1c;
            padding: 40px 8%;
            text-align: center;
            color: #555558;
            font-size: 14px;
        }
    </style>
</head>
<body>

    <nav>
        <a href="/" class="logo">Kontakt<span>Home</span></a>
  <ul class="nav-links">
    <li><a href="/">Ana Səhifə</a></li>
    <li><a href="/mehsullar">Məhsullar</a></li>
    <li><a href="/brendler">Brendlər</a></li>
    <li><a href="/kampaniyalar">Kampaniyalar</a></li> 
    <li><a href="/magazalar">Mağazalar</a></li>
    <li><a href="/kreditler">Kredit</a></li>
</ul>
        <div class="nav-right">
            <button class="icon-btn">🔍</button>
            <button class="icon-btn">❤️</button>
            <button class="cart-btn">Səbət (0)</button>
        </div>
    </nav>

    <div class="page-header">
        <h1>Partnyor Brendlərimiz</h1>
        <p>Dünyanın ən qabaqcıl və etibarlı istehsalçılarının rəsmi məhsulları bir məkanda.</p>
    </div>

    <div class="container">
        
        <div class="search-bar-wrapper">
            <input type="text" class="brand-search-input" placeholder="Brend adı ilə axtar...">
        </div>

        <div class="brands-grid">
            
            <div class="brand-card">
                <div class="brand-logo-placeholder"></div>
                <div class="brand-name">Apple</div>
                <div class="brand-count">45 məhsul</div>
            </div>

            <div class="brand-card">
                <div class="brand-logo-placeholder">S</div>
                <div class="brand-name">Samsung</div>
                <div class="brand-count">82 məhsul</div>
            </div>

            <div class="brand-card">
                <div class="brand-logo-placeholder">X</div>
                <div class="brand-name">Xiaomi</div>
                <div class="brand-count">61 məhsul</div>
            </div>

            <div class="brand-card">
                <div class="brand-logo-placeholder">A</div>
                <div class="brand-name">Asus</div>
                <div class="brand-count">24 məhsul</div>
            </div>

            <div class="brand-card">
                <div class="brand-logo-placeholder">L</div>
                <div class="brand-name">LG</div>
                <div class="brand-count">33 məhsul</div>
            </div>

            <div class="brand-card">
                <div class="brand-logo-placeholder">H</div>
                <div class="brand-name">Huawei</div>
                <div class="brand-count">19 məhsul</div>
            </div>

            <div class="brand-card">
                <div class="brand-logo-placeholder">S</div>
                <div class="brand-name">Sony</div>
                <div class="brand-count">14 məhsul</div>
            </div>

            <div class="brand-card">
                <div class="brand-logo-placeholder">B</div>
                <div class="brand-name">Bosch</div>
                <div class="brand-count">56 məhsul</div>
            </div>

        </div>
    </div>

    <footer>
        <p>&copy; 2026 Kontakt Home Tədris Layihəsi. Bütün hüquqlar qorunur.</p>
    </footer>

</body>
</html>